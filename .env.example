# 复制为 .env 并填写。不配置 LLM 也能运行（自动降级为启发式推导）。
# OpenAI 兼容接口；base_url 可指向任意兼容服务（如 MiniMax / 本地 / 代理）。
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M3
LLM_TEMPERATURE=0
LLM_PARALLEL_TOOL_CALLS=true

# Agent 单段安全边界，不是业务流程轮次。达到上下文或调用边界且已有检查点时，
# 平台会自动切换到新的模型上下文继续同一任务。
AGENT_MODEL_CALL_LIMIT=64
AGENT_GRAPH_RECURSION_LIMIT=512
AGENT_AUTO_CONTINUATION_LIMIT=4
AGENT_CONTEXT_SUMMARIZE_TOKENS=96000
AGENT_CONTEXT_KEEP_TOKENS=24000

# 数据存储根目录（相对项目根；每个业务场景独立隔离）
DATA_DIR=data
# 系统数据（用户库等 SQLite）目录，随项目自管理，无需外部数据库
SYSTEM_DIR=system

# 服务监听地址
HOST=127.0.0.1
PORT=8000

# ===== Studio Skill 运行环境 =====
# Studio 自动在系统数据目录中维护一个共享 venv，不会在业务场景目录创建环境。
# Skill 完整目录以只读 /skills 暴露；当前场景工作区映射为可写 /workspace。
SANDBOX_PROVIDER=venv
# 可选：自定义系统级运行目录；留空时使用 Studio 的系统数据目录。
# SANDBOX_ROOT=system/studio-runtime
SANDBOX_COMMAND_TIMEOUT=900
SANDBOX_OUTPUT_LIMIT=128000

# 内置 Skill 的凭据由服务端注入到单次命令环境，不写入 Skill 包或业务场景文件。
OCR_BASE_URL=
OCR_API_KEY=
OCR_TIMEOUT_SECONDS=300
OCR_VERIFY_SSL=true
VECTOR_KB_BASE_URL=
VECTOR_KB_LIBRARY_ID=
VECTOR_KB_API_KEY=
VECTOR_KB_TIMEOUT_SECONDS=60

# ===== MCP 对外交付（第三方远程挂载能力用）=====
# 第三方宿主挂载本平台能力的公网基址。
# 开发/测试：留空即可——安装链接会按访问本服务所用的主机地址（本机 IP / 域名）自动生成。
# 正式环境：填固定域名，例如 https://mcp.example.com （第三方据此拼接 /api/mcp/<场景>/sse）。
MCP_PUBLIC_BASE_URL=
# 可选：远程 MCP 访问令牌。留空 = 端点公开；填值后 /api/mcp/* 需带 Authorization: Bearer <token>
# （生成给第三方的配置会自动带上该令牌，无需第三方手工填写）。
MCP_ACCESS_TOKEN=

# ===== 鉴权（JWT）=====
# 生产环境务必改成随机长字符串
JWT_SECRET=change-me-in-production-please
JWT_EXPIRE_HOURS=168
# 前端地址（OAuth 登录成功后回跳目标）
FRONTEND_BASE_URL=http://127.0.0.1:5173
# 后端对外基址（拼接 OAuth 回调地址用）
OAUTH_REDIRECT_BASE=http://127.0.0.1:8000

# ===== 可插拔 OAuth（留空则前端不显示对应按钮）=====
# Google：回调地址填 <OAUTH_REDIRECT_BASE>/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub：回调地址填 <OAUTH_REDIRECT_BASE>/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
