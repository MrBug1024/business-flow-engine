# 复制为 .env 并填写。不配置 LLM 也能运行（自动降级为启发式推导）。
# OpenAI 兼容接口；base_url 可指向任意兼容服务（如 MiniMax / 本地 / 代理）。
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M3
LLM_TEMPERATURE=0

# 数据存储根目录（相对项目根；每个业务场景独立隔离）
DATA_DIR=data
# 系统数据（用户库等 SQLite）目录，随项目自管理，无需外部数据库
SYSTEM_DIR=system

# 服务监听地址
HOST=127.0.0.1
PORT=8000

# ===== 鉴权（JWT）=====
# 生产环境务必改成随机长字符串
JWT_SECRET=change-me-in-production-please
JWT_EXPIRE_HOURS=168
# 前端地址（OAuth 登录成功后回跳目标）
FRONTEND_BASE_URL=http://127.0.0.1:5173
# 后端对外基址（拼接 OAuth 回调地址用）
OAUTH_REDIRECT_BASE=http://127.0.0.1:8000

# ===== 可插拔 OAuth（留空则前端不显示对应按钮）=====
# Google：回调地址填 <OAUTH_REDIRECT_BASE>/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub：回调地址填 <OAUTH_REDIRECT_BASE>/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
