# 复制为 .env 并填写。不配置 LLM 也能运行（自动降级为启发式推导）。
# OpenAI 兼容接口；base_url 可指向任意兼容服务（如 MiniMax / 本地 / 代理）。
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M3
LLM_TEMPERATURE=0
LLM_PARALLEL_TOOL_CALLS=true

# Agent 单段安全边界，不是业务流程轮次。达到上下文或调用边界且已有检查点时，
# 平台会自动切换到新的模型上下文继续同一任务。
AGENT_MODEL_CALL_LIMIT=64
AGENT_GRAPH_RECURSION_LIMIT=512
AGENT_AUTO_CONTINUATION_LIMIT=4
AGENT_CONTEXT_SUMMARIZE_TOKENS=96000
AGENT_CONTEXT_KEEP_TOKENS=24000
AGENT_HISTORY_MESSAGE_LIMIT=12
AGENT_HISTORY_CHARACTER_LIMIT=32000
AGENT_SYSTEM_PROMPT_CHARACTER_LIMIT=12000
AGENT_TOOL_SCHEMA_CHARACTER_LIMIT=40000

# 纯业务数据根目录；实际场景位于 data/accounts/<账户ID>/<场景ID>/
DATA_DIR=data
# 全部系统内部状态根目录：账户、设置、运行时、沙箱、日志和用户能力
SYSTEM_DIR=system

# 服务监听地址
HOST=127.0.0.1
PORT=8000

# ===== Studio Skill 运行环境 =====
# Studio 自动在 system/runtime/sandbox 中维护共享 venv，不会污染 data/。
# Skill 完整目录以只读 /skills 暴露；当前场景工作区映射为可写 /workspace。
SANDBOX_PROVIDER=venv
# 可选：自定义系统级运行目录；留空时使用 Studio 的系统数据目录。
# SANDBOX_ROOT=system/runtime/sandbox
SANDBOX_COMMAND_TIMEOUT=900
SANDBOX_OUTPUT_LIMIT=128000

# 内置 Skill 的凭据由服务端注入到单次命令环境，不写入 Skill 包或业务场景文件。
OCR_BASE_URL=
OCR_API_KEY=
OCR_TIMEOUT_SECONDS=300
OCR_VERIFY_SSL=true
VECTOR_KB_BASE_URL=
VECTOR_KB_LIBRARY_ID=
VECTOR_KB_API_KEY=
VECTOR_KB_TIMEOUT_SECONDS=60

# ===== MCP 对外交付预留 =====
# 当前版本作为 MCP 客户端连接外部服务；以下变量为未来公共 MCP Server 链路预留。
MCP_PUBLIC_BASE_URL=
# 预留的远程访问令牌；当前版本不会据此创建 /api/mcp/* 公共端点。
MCP_ACCESS_TOKEN=

# ===== 鉴权（JWT）=====
# 生产环境务必改成随机长字符串
JWT_SECRET=change-me-in-production-please
JWT_EXPIRE_HOURS=168
AUTH_COOKIE_NAME=studio_session
# HTTPS 部署时改为 true；本机 http 开发保持 false。
AUTH_COOKIE_SECURE=false
VERIFICATION_CODE_TTL_MINUTES=10
VERIFICATION_CODE_RESEND_SECONDS=60
VERIFICATION_CODE_MAX_PER_HOUR=5
VERIFICATION_CODE_MAX_ATTEMPTS=5

# ===== 邮件通知（注册验证码）=====
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.163.com
MAIL_STARTTLS=false
MAIL_SSL_TLS=true
MAIL_USE_CREDENTIALS=true
MAIL_TIMEOUT_SECONDS=20
# 前端地址（OAuth 登录成功后回跳目标）
FRONTEND_BASE_URL=http://127.0.0.1:5173
# 后端对外基址（拼接 OAuth 回调地址用）
OAUTH_REDIRECT_BASE=http://127.0.0.1:8000
